        "def plot_attention_map(text, model=ALL_MODELS['LSTM']):\n",
        "    # 1. Preprocess the input text\n",
        "    cleaned = re.sub(r\"[^a-zA-Z0-9\\s\\-]\", \" \", str(text).lower())\n",
        "    seq = pad_sequences(tokenizer.texts_to_sequences([cleaned]),\n",
        "                        maxlen=MAX_LEN, padding='post', truncating='post')\n",
        "\n",
        "    # 2. Extract attention weights\n",
        "    # We create a sub-model that outputs the attention weights from the 'attention' layer\n",
        "    attn_layer_model = keras.Model(inputs=model.input,\n",
        "                                   outputs=model.get_layer('attention').output)\n",
        "    context_vec, weights = attn_layer_model.predict(seq, verbose=0)\n",
        "\n",
        "    # 3. Map weights back to words\n",
        "    words = cleaned.split()[:MAX_LEN]\n",
        "    weight_scores = weights[0][:len(words)]\n",
        "\n",
        "    # 4. Plotting\n",
        "    plt.figure(figsize=(15, 3))\n",
        "    sns.barplot(x=list(range(len(words))), y=weight_scores, palette=\"viridis\")\n",
        "    plt.xticks(ticks=range(len(words)), labels=words, rotation=45, ha='right')\n",
        "    plt.title(f\"Attention weights for: {text[:50]}...\", fontweight='bold')\n",
        "    plt.ylabel(\"Attention Score\")\n",
        "    plt.tight_layout()\n",
