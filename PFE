        "def normalise_cat(cat):\n",
        "    c = str(cat).strip().lower()\n",
        "    if \"edible\" in c:                                 return \"edible\"\n",
        "    if \"poison\" in c and \"food\" not in c:             return \"poisonous\"\n",
        "    if \"food_poison\" in c or \"food poisoning\" in c:   return \"food_poisoning\"\n",
        "    return \"other\"\n",
        "def clean_text(t):\n",
        "    t = str(t) if pd.notna(t) else \"\"\n",
        "    t = re.sub(r\"http\\S+\", \" \", t)\n",
        "    t = re.sub(r\"[^a-zA-Z0-9\\s\\-]\", \" \", t)\n",
        "    return re.sub(r\"\\s+\", \" \", t).strip().lower()\n",
        "raw[\"label\"] = raw[\"category\"].apply(normalise_cat)\n",
        "df = (raw[raw[\"label\"] != \"other\"]\n",
        "      .drop_duplicates(subset=[\"name\",\"category\"], keep=\"first\")\n",
        "      .reset_index(drop=True))\n",
        "df[\"text\"] = (df[\"name\"].fillna(\"\").apply(clean_text) + \" \" +\n",
        "              df[\"scientific_name\"].fillna(\"\").apply(clean_text) + \" \" +\n",
        "              df[\"description\"].fillna(\"\").apply(clean_text))\n",
        "le = LabelEncoder()\n",
        "df[\"y\"] = le.fit_transform(df[\"label\"])\n",
        "CLASS_NAMES = le.classes_\n",
        "N_CLASSES   = len(CLASS_NAMES)\n",
        "print(f\"Samples: {len(df):,}  |  Classes: {dict(zip(CLASS_NAMES, le.transform(CLASS_NAMES)))}\")"
