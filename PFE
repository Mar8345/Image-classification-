        "auc_stack = roc_auc_score(y_test, prob_stack2, multi_class=\"ovr\", average=\"weighted\")\n",
        "RESULTS[\"Stacking LR\"] = {\"Accuracy\": acc_stack, \"F1\": f1_stack, \"AUC\": auc_stack}\n",
        "ALL_PROBS[\"Stacking LR\"] = prob_stack2\n",
        "print(f\"Stacking LR  Acc={acc_stack:.4f}  F1={f1_stack:.4f}  AUC={auc_stack:.4f}\")"
      ]
