        "import keras\n",
        "from keras import layers\n",
        "\n",
        "class AdditiveAttention(layers.Layer):\n",
        "    def __init__(self, units=64, **kwargs):\n",
        "        super().__init__(**kwargs)\n",
        "        self.units = units\n",
        "    def build(self, input_shape):\n",
        "        self.W = layers.Dense(self.units, use_bias=False, activation='tanh')\n",
        "        self.V = layers.Dense(1, use_bias=False)\n",
        "        super().build(input_shape)\n",
        "    def call(self, x):\n",
        "        score = self.V(self.W(x))\n",
        "        score = tf.squeeze(score, axis=-1)\n",
        "        attn_weights = tf.nn.softmax(score, axis=-1)\n",
        "        context = tf.reduce_sum(\n",
        "            x * tf.expand_dims(attn_weights, axis=-1), axis=1\n",
        "        )\n",
        "        return context, attn_weights\n",
        "\n",
        "def build_lstm():\n",
        "    inp = keras.Input(shape=(MAX_LEN,), name=\"input\")\n",
        "    emb = layers.Embedding(VOCAB_SIZE, EMBED_DIM, name=\"embedding\")(inp)\n",
        "\n",
        "    # SpatialDropout1D provides strong regularization across the sequence\n",
        "    x = layers.SpatialDropout1D(0.3)(emb)\n",
        "\n",
        "    # Removed recurrent_dropout to enable cuDNN acceleration\n",
        "    # Increased standard dropout to 0.4 to compensate\n",
        "    x = layers.Bidirectional(layers.LSTM(128, return_sequences=True,\n",
        "                                         dropout=0.4),\n",
        "                             name=\"bilstm_1\")(x)\n",
        "    x = layers.Bidirectional(layers.LSTM(64, return_sequences=True,\n",
        "                                         dropout=0.4),\n",
        "                             name=\"bilstm_2\")(x)\n",
        "\n",
        "    x, _ = AdditiveAttention(name=\"attention\")(x)\n",
        "\n",
        "    x = layers.Dense(256, activation=\"relu\",\n",
        "                     kernel_regularizer=keras.regularizers.l2(1e-4))(x)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.Dropout(0.4)(x)\n",
        "    x = layers.Dense(128, activation=\"relu\")(x)\n",
        "    x = layers.Dropout(0.3)(x)\n",
        "\n",
        "    out = layers.Dense(N_CLASSES, activation=\"softmax\", name=\"output\")(x)\n",
        "\n",
        "    m = keras.Model(inp, out, name=\"LSTM\")\n",
        "    m.compile(optimizer=keras.optimizers.Adam(8e-4),\n",
        "              loss=\"sparse_categorical_crossentropy\",\n",
        "              metrics=[\"accuracy\"])\n",
        "    return m\n",
        "\n",
        "lstm_m = build_lstm()\n",
        "print(\"Transferring Transformer embedding -> LSTM ...\")\n",
        "transfer_embedding(transformer_m, lstm_m)\n",
        "\n",
        "set_embed_trainable(lstm_m, trainable=False)\n",
        "lstm_m.fit(X_resampled, y_resampled,\n",
        "           validation_data=(X_val_enc, y_val),\n",
        "           epochs=8, batch_size=BATCH,\n",
        "           callbacks=get_cbs(), verbose=0)\n",
        "\n",
        "set_embed_trainable(lstm_m, trainable=True)\n",
        "lstm_m.compile(optimizer=keras.optimizers.Adam(8e-4),\n",
        "               loss=\"sparse_categorical_crossentropy\",\n",
        "               metrics=[\"accuracy\"])\n",
        "\n",
        "h_lstm = lstm_m.fit(X_resampled, y_resampled,\n",
