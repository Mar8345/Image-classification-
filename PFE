        "def build_transformer():\n",
        "    inp = keras.Input(shape=(MAX_LEN,), name=\"input\")\n",
        "    emb = layers.Embedding(VOCAB_SIZE, EMBED_DIM, name=\"embedding\")(inp)\n",
        "\n",
        "    attn_output = layers.MultiHeadAttention(num_heads=4, key_dim=EMBED_DIM)(emb, emb)\n",
        "    attn_output = layers.Dropout(0.2)(attn_output)\n",
        "    out1 = layers.LayerNormalization(epsilon=1e-6)(emb + attn_output)\n",
        "\n",
        "    ffn_output = layers.Dense(256, activation=\"relu\")(out1)\n",
        "    ffn_output = layers.Dense(EMBED_DIM)(ffn_output)\n",
        "    ffn_output = layers.Dropout(0.2)(ffn_output)\n",
        "    out2 = layers.LayerNormalization(epsilon=1e-6)(out1 + ffn_output)\n",
        "\n",
        "    x = layers.GlobalAveragePooling1D()(out2)\n",
        "    x = layers.Dropout(0.3)(x)\n",
        "    x = layers.Dense(128, activation=\"relu\")(x)\n",
        "    x = layers.Dropout(0.3)(x)\n",
        "\n",
        "    out = layers.Dense(N_CLASSES, activation=\"softmax\", name=\"output\")(x)\n",
        "    m = keras.Model(inp, out, name=\"Transformer\")\n",
        "    m.compile(\n",
        "        optimizer=keras.optimizers.Adam(1e-3),\n",
        "        loss=\"sparse_categorical_crossentropy\",\n",
        "        metrics=[\"accuracy\"],\n",
        "    )\n",
        "    return m\n",
        "\n",
        "transformer_m = build_transformer()\n",
        "print(\"Transferring CNN embedding -> Transformer...\")\n",
        "transfer_embedding(cnn, transformer_m)\n",
        "set_embed_trainable(transformer_m, trainable=False)\n",
