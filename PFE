        "---\n",
        "  ## 7. Soft-Voting & Stacking Meta-Learner\n",
        "\n",
        "  Beyond the joint ensemble, we also combine individual model predictions via:\n",
        "  - **Soft voting** (averaged probabilities)\n",
        "  - **Stacking** (logistic regression on concatenated softmax outputs)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "p4IrpqKQGELH"
      },
      "outputs": [],
      "source": [
        "from sklearn.linear_model import LogisticRegression as SkLR\n",
        "prob_stack = np.stack([ALL_PROBS[n] for n in [\"ANN\",\"CNN\",\"Transformer\",\"LSTM\",\"GRU\"]], axis=0)\n",
        "prob_avg   = prob_stack.mean(axis=0)\n",
        "yp_vote    = prob_avg.argmax(1)\n",
        "acc_vote = accuracy_score(y_test, yp_vote)\n",
        "f1_vote  = f1_score(y_test, yp_vote, average=\"weighted\")\n",
        "auc_vote = roc_auc_score(y_test, prob_avg, multi_class=\"ovr\", average=\"weighted\")\n",
        "RESULTS[\"Soft Voting\"] = {\"Accuracy\": acc_vote, \"F1\": f1_vote, \"AUC\": auc_vote}\n",
        "ALL_PROBS[\"Soft Voting\"] = prob_avg\n",
        "print(f\"Soft Voting  Acc={acc_vote:.4f}  F1={f1_vote:.4f}  AUC={auc_vote:.4f}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "Si9S7zypGELH"
      },
      "outputs": [],
      "source": [
        "X_meta_val  = np.hstack([ALL_MODELS[n].predict(X_val_enc,  verbose=0)\n",
        "                          for n in [\"ANN\",\"CNN\",\"Transformer\",\"LSTM\",\"GRU\"]])\n",
        "X_meta_test = np.hstack([ALL_PROBS[n] for n in [\"ANN\",\"CNN\",\"Transformer\",\"LSTM\",\"GRU\"]])\n",
        "meta = SkLR(C=1.0, max_iter=500, random_state=42)\n",
        "meta.fit(X_meta_val, y_val)\n",
        "yp_stack    = meta.predict(X_meta_test)\n",
