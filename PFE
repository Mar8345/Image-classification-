        "---\n",
        "  ## 4. Shared Architecture Components\n",
        "\n",
        "  All 5 models share the **same** embedding matrix initialization and a custom **Self-Attention** layer.\n",
        "  Weight transfer ensures each trained model \"teaches\" the next via its learned embedding.\n",
        "\n",
        "  ```\n",
        "  Stage:   ANN -> embed -> CNN -> embed -> Transformer -> embed -> LSTM -> embed -> GRU\n",
        "           transfer        transfer          transfer          transfer\n",
        "  ```\n",
        "  "
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "8iMSXIjzGELC"
      },
      "outputs": [],
      "source": [
        "class AdditiveAttention(layers.Layer):\n",
        "    def __init__(self, **kw): super().__init__(**kw)\n",
        "    def build(self, shape):\n",
        "        self.W = self.add_weight(\"W\", shape=(shape[-1], 64),\n",
        "                                 initializer=\"glorot_uniform\", trainable=True)\n",
        "        self.v = self.add_weight(\"v\", shape=(64, 1),\n",
        "                                 initializer=\"glorot_uniform\", trainable=True)\n",
        "        super().build(shape)\n",
        "    def call(self, x):\n",
        "        score = tf.squeeze(tf.matmul(tf.tanh(tf.matmul(x, self.W)), self.v), -1)\n",
        "        alpha = tf.nn.softmax(score, axis=-1)\n",
        "        return tf.reduce_sum(x * tf.expand_dims(alpha, -1), axis=1), alpha\n",
        "\n",
        "def set_embed_trainable(model, trainable, layer_name=\"embedding\"):\n",
        "    model.get_layer(layer_name).trainable = trainable\n",
        "    model.compile(\n",
        "        optimizer=model.optimizer,\n",
        "        loss=\"sparse_categorical_crossentropy\",\n",
        "        metrics=[\"accuracy\"]\n",
        "    )\n",
        "\n",
        "def transfer_embedding(src_model, dst_model, layer_name=\"embedding\"):\n",
        "    w = src_model.get_layer(layer_name).get_weights()\n",
        "    dst_model.get_layer(layer_name).set_weights(w)\n",
        "    print(f\"  ✓ Embedding transferred: {src_model.name} → {dst_model.name}\")\n",
        "\n",
        "BATCH   = 128\n",
        "EPOCHS  = 60\n",
        "RESULTS = {}\n",
        "ALL_MODELS = {}\n",
        "ALL_PROBS  = {}\n",
        "\n",
        "def get_cbs(model_name=\"model\"):\n",
        "    \"\"\"Generates standard callbacks including EarlyStopping, ReduceLROnPlateau, and ModelCheckpoint.\"\"\"\n",
        "    os.makedirs(\"checkpoints\", exist_ok=True)\n",
        "    return [\n",
        "        EarlyStopping(monitor=\"val_loss\", patience=8,\n",
        "                      restore_best_weights=True, verbose=0),\n",
        "        ReduceLROnPlateau(monitor=\"val_loss\", factor=0.5,\n",
        "                          patience=4, min_lr=1e-6, verbose=0),\n",
        "        ModelCheckpoint(filepath=f\"checkpoints/{model_name}_best.keras\",\n",
        "                        monitor=\"val_loss\", save_best_only=True, verbose=0)\n",
        "    ]\n",
        "\n",
        "def evaluate(name, model):\n",
        "    y_prob = model.predict(X_test_enc, verbose=0)\n",
        "    y_pred = y_prob.argmax(1)\n",
        "    acc = accuracy_score(y_test, y_pred)\n",
        "    f1  = f1_score(y_test, y_pred, average=\"weighted\")\n",
        "    auc_s = roc_auc_score(y_test, y_prob, multi_class=\"ovr\", average=\"weighted\")\n",
        "    RESULTS[name] = {\"Accuracy\": acc, \"F1\": f1, \"AUC\": auc_s}\n",
        "    ALL_PROBS[name] = y_prob\n",
        "    print(f\"  Accuracy {acc:.4f}  |  F1 {f1:.4f}  |  AUC {auc_s:.4f}\")\n",
        "    print(classification_report(y_test, y_pred, target_names=CLASS_NAMES))\n",
        "    return y_pred, y_prob\n",
        "\n",
        "def plot_hist(h, title):\n",
        "    fig, ax = plt.subplots(1, 2, figsize=(13, 4))\n",
        "    for a, (k1,k2), lbl in zip(ax,\n",
        "            [(\"loss\",\"val_loss\"),(\"accuracy\",\"val_accuracy\")],[\"Loss\",\"Accuracy\"]):\n",
        "        a.plot(h.history[k1], label=\"Train\", color=\"#2196F3\", lw=2)\n",
        "        a.plot(h.history[k2], label=\"Val\",   color=\"#F44336\", lw=2)\n",
        "        a.set_title(f\"{title} — {lbl}\", fontweight=\"bold\")\n",
        "        a.set_xlabel(\"Epoch\"); a.legend()\n",
        "    plt.tight_layout(); plt.show()\n",
        "\n",
        "def plot_cm(yt, yp, title):\n",
        "    fig, ax = plt.subplots(figsize=(7,5))\n",
        "    ConfusionMatrixDisplay(confusion_matrix(yt,yp),\n",
        "                           display_labels=CLASS_NAMES).plot(ax=ax,colorbar=False,cmap=\"Blues\")\n",
        "    ax.set_title(title, fontweight=\"bold\"); plt.tight_layout(); plt.show()\n",
        "\n",
        "print(\"Shared components updated with ModelCheckpoint ✓\")"
      ]
