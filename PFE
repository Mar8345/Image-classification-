      },
      "source": [
        "---\n",
        "  ## 6. Unified Ensemble - All 5 Models Combined\n",
        "\n",
        "  ### Architecture\n",
        "  A **single Keras model** with one shared embedding layer and 5 parallel branches.\n",
        "  The branches' feature vectors are concatenated and passed through a meta-classifier.\n",
        "  The final GRU embedding (the most refined) seeds the shared embedding.\n",
        "\n",
        "  ```\n",
        "                 +-- ANN branch (GAP -> Dense 128) ------+\n",
        "                 |                                       |\n",
        "                 +-- CNN branch (Conv1D x4 -> MaxPool) --+\n",
        "                 |                                       |\n",
        "  Input -> Emb --+-- Transformer branch (MHA -> FFN -> GAP) --+-> Concat -> BN -> Dense -> Softmax\n",
        "                 |                                       |\n",
        "                 +-- LSTM branch (BiLSTM -> Attention) --+\n",
        "                 |                                       |\n",
        "                 +-- GRU branch (BiGRU -> MHA -> GAP) ---+\n",
        "  ```"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "9912c164"
      },
      "source": [
        "### Unified Ensemble Strategy\n",
        "This final model combines all previous architectural strengths into a single graph. By concatenating the high-level features from the ANN, CNN, Transformer, LSTM, and GRU branches, the meta-classifier can make a decision based on both local feature detection and global sequence understanding."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "LWT3RcytGELG"
      },
      "outputs": [],
      "source": [
        "def build_ensemble(vocab=VOCAB_SIZE, edim=EMBED_DIM,\n",
        "                   maxlen=MAX_LEN, n_cls=N_CLASSES):\n",
        "    inp = keras.Input(shape=(maxlen,), name=\"input\")\n",
        "    shared_emb = layers.Embedding(vocab, edim, name=\"embedding\")(inp)\n",
        "    sd = layers.SpatialDropout1D(0.25)(shared_emb)\n",
        "    ann_x = layers.GlobalAveragePooling1D(name=\"ann_gap\")(sd)\n",
        "    ann_x = layers.Dense(128, activation=\"relu\", name=\"ann_d1\")(ann_x)\n",
        "    ann_x = layers.BatchNormalization(name=\"ann_bn\")(ann_x)\n",
        "    ann_x = layers.Dropout(0.35, name=\"ann_drop\")(ann_x)\n",
        "    cnn_branches = []\n",
        "    for k in (2, 3, 4, 5):\n",
        "        b = layers.Conv1D(64, k, activation=\"relu\",\n",
        "                          padding=\"valid\", name=f\"ens_conv_k{k}\")(sd)\n",
        "        b = layers.GlobalMaxPooling1D(name=f\"ens_pool_k{k}\")(b)\n",
        "        cnn_branches.append(b)\n",
        "    cnn_x = layers.Concatenate(name=\"cnn_concat\")(cnn_branches)\n",
        "    cnn_x = layers.Dense(128, activation=\"relu\", name=\"cnn_d1\")(cnn_x)\n",
        "    cnn_x = layers.Dropout(0.35, name=\"cnn_drop\")(cnn_x)\n",
        "    tr_attn = layers.MultiHeadAttention(num_heads=4, key_dim=edim,\n",
        "                                        name=\"tr_mha\")(sd, sd)\n",
        "    tr_attn = layers.Dropout(0.2, name=\"tr_attn_drop\")(tr_attn)\n",
        "    tr_out1 = layers.LayerNormalization(epsilon=1e-6, name=\"tr_ln1\")(sd + tr_attn)\n",
        "    tr_ffn = layers.Dense(256, activation=\"relu\", name=\"tr_ffn1\")(tr_out1)\n",
        "    tr_ffn = layers.Dense(edim, name=\"tr_ffn2\")(tr_ffn)\n",
        "    tr_ffn = layers.Dropout(0.2, name=\"tr_ffn_drop\")(tr_ffn)\n",
        "    tr_out2 = layers.LayerNormalization(epsilon=1e-6, name=\"tr_ln2\")(tr_out1 + tr_ffn)\n",
        "    tr_x = layers.GlobalAveragePooling1D(name=\"tr_gap\")(tr_out2)\n",
        "    tr_x = layers.Dense(128, activation=\"relu\", name=\"tr_d1\")(tr_x)\n",
        "    tr_x = layers.Dropout(0.35, name=\"tr_drop\")(tr_x)\n",
        "    lstm_x = layers.Bidirectional(layers.LSTM(64, return_sequences=True,\n",
        "                 dropout=0.4),\n",
        "                 name=\"ens_bilstm\")(sd)\n",
        "    lstm_x, _ = AdditiveAttention(name=\"ens_attention\")(lstm_x)\n",
        "    lstm_x = layers.Dense(128, activation=\"relu\", name=\"lstm_d1\")(lstm_x)\n",
        "    lstm_x = layers.Dropout(0.35, name=\"lstm_drop\")(lstm_x)\n",
        "    gru_x = layers.Bidirectional(layers.GRU(64, return_sequences=True,\n",
        "                dropout=0.4, reset_after=True),\n",
        "                name=\"ens_bigru\")(sd)\n",
        "    mha   = layers.MultiHeadAttention(num_heads=2, key_dim=32, name=\"ens_mha\")(gru_x, gru_x)\n",
        "    gru_x = layers.Add()([gru_x, mha])\n",
        "    gru_x = layers.LayerNormalization(name=\"ens_ln\")(gru_x)\n",
        "    gru_x = layers.GlobalAveragePooling1D(name=\"gru_gap\")(gru_x)\n",
        "    gru_x = layers.Dense(128, activation=\"relu\", name=\"gru_d1\")(gru_x)\n",
        "    gru_x = layers.Dropout(0.35, name=\"gru_drop\")(gru_x)\n",
        "    fused = layers.Concatenate(name=\"fusion\")([ann_x, cnn_x, tr_x, lstm_x, gru_x])\n",
        "    fused = layers.Dense(512, activation=\"relu\", name=\"meta_d1\")(fused)\n",
        "    fused = layers.BatchNormalization(name=\"meta_bn1\")(fused)\n",
        "    fused = layers.Dropout(0.4)(fused)\n",
        "    fused = layers.Dense(256, activation=\"relu\", name=\"meta_d2\")(fused)\n",
        "    fused = layers.BatchNormalization(name=\"meta_bn2\")(fused)\n",
        "    fused = layers.Dropout(0.35)(fused)\n",
        "    out   = layers.Dense(n_cls, activation=\"softmax\", name=\"output\")(fused)\n",
        "    model = keras.Model(inp, out, name=\"Ensemble_ANN_CNN_TRANSFORMER_LSTM_GRU\")\n",
        "    model.compile(\n",
        "        optimizer=keras.optimizers.Adam(5e-4),\n",
        "        loss=\"sparse_categorical_crossentropy\",\n",
        "        metrics=[\"accuracy\"]\n",
        "    )\n",
        "    return model\n",
        "ensemble = build_ensemble()\n",
        "print(f\"Ensemble parameters: {ensemble.count_params():,}\")\n",
        "transfer_embedding(gru_m, ensemble)\n",
        "ensemble.summary()"
      ]
    },
