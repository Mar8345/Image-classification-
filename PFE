        "import keras\n",
        "from keras import layers, regularizers\n",
        "\n",
        "def build_gru():\n",
        "    inp = keras.Input(shape=(MAX_LEN,), name=\"input\")\n",
        "    emb = layers.Embedding(VOCAB_SIZE, EMBED_DIM, name=\"embedding\")(inp)\n",
        "\n",
        "    # SpatialDropout1D provides strong regularization across the sequence\n",
        "    x = layers.SpatialDropout1D(0.3)(emb)\n",
        "\n",
        "    # Removed recurrent_dropout to enable cuDNN acceleration\n",
        "    # Increased standard dropout to 0.4 to compensate\n",
        "    # Added reset_after=True which is required for cuDNN GRU implementation\n",
        "    x = layers.Bidirectional(layers.GRU(128, return_sequences=True,\n",
        "                                        dropout=0.4,\n",
        "                                        reset_after=True),\n",
        "                             name=\"bigru_1\")(x)\n",
        "    x = layers.Bidirectional(layers.GRU(64, return_sequences=True,\n",
        "                                        dropout=0.4,\n",
        "                                        reset_after=True),\n",
        "                             name=\"bigru_2\")(x)\n",
        "\n",
        "    mha = layers.MultiHeadAttention(num_heads=2, key_dim=64,\n",
        "                                    dropout=0.2, name=\"mha\")(x, x)\n",
        "    x = layers.Add()([x, mha])\n",
        "    x = layers.LayerNormalization()(x)\n",
        "    x = layers.GlobalAveragePooling1D(name=\"gap\")(x)\n",
        "\n",
        "    x = layers.Dense(256, activation=\"relu\",\n",
        "                     kernel_regularizer=regularizers.l2(1e-4))(x)\n",
        "    x = layers.BatchNormalization()(x)\n",
        "    x = layers.Dropout(0.4)(x)\n",
        "    x = layers.Dense(128, activation=\"relu\")(x)\n",
        "    x = layers.Dropout(0.3)(x)\n",
        "\n",
        "    out = layers.Dense(N_CLASSES, activation=\"softmax\", name=\"output\")(x)\n",
        "\n",
        "    m = keras.Model(inp, out, name=\"GRU\")\n",
        "    m.compile(optimizer=keras.optimizers.Adam(8e-4),\n",
        "              loss=\"sparse_categorical_crossentropy\",\n",
        "              metrics=[\"accuracy\"])\n",
        "    return m\n",
        "\n",
        "gru_m = build_gru()\n",
        "print(\"Transferring LSTM embedding -> GRU ...\")\n",
        "transfer_embedding(lstm_m, gru_m)\n",
        "\n",
        "set_embed_trainable(gru_m, trainable=False)\n",
        "gru_m.fit(X_resampled, y_resampled,\n",
